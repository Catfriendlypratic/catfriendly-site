            &lt;path d="M7 15h4" stroke="#c45572" stroke-width="2" stroke-linecap="round"/&gt;
          &lt;/svg&gt;
        &lt;/div&gt;
        &lt;h3&gt;Artigos e Revistas&lt;/h3&gt;
        &lt;p&gt;Acesse publicações e consensos sobre manejo felino.&lt;/p&gt;
        &lt;a class="mini-btn" href="#artigos"&gt;Leia os Artigos&lt;/a&gt;
      &lt;/div&gt;

      &lt;div class="feature"&gt;
        &lt;div class="icon" aria-hidden="true"&gt;
