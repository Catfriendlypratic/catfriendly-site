mx-auto pt-12 [--thread-content-margin:--spacing(4)] @w-sm/main:[--thread-content-margin:--spacing(6)] @w-lg/main:[--thread-content-margin:--spacing(16)] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col" tabindex="-1"><div class="flex max-w-full flex-col grow"><div data-message-author-role="user" data-message-id="a153c4a0-be94-49f3-b232-a26229336858" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/1.1 relative rounded-[18px] px-4 py-1.5 data-[multiline]:py-3 max-w-[var(--user-chat-width,70%)]" data-multiline=""><div class="whitespace-pre-wrap">&lt;!DOCTYPE html&gt;
&lt;html lang="pt-BR"&gt;
&lt;head&gt;
  &lt;meta charset="UTF-8" /&gt;
  &lt;meta name="viewport" content="width=device-width, initial-scale=1.0" /&gt;
  &lt;title&gt;Projeto CatFriendly | LAMF – UNIFAA&lt;/title&gt;
  &lt;link rel="preconnect" href="https://fonts.googleapis.com"&gt;
  &lt;link rel="preconnect" href="https://fonts.gstatic.com" crossorigin&gt;
  &lt;link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&amp;display=swap" rel="stylesheet"&gt;

  &lt;style&gt;
    :root{
      --pink-700:#cf4f79;
      --pink-600:#e26a93;
      --pink-500:#f08fb0;
      --pink-200:#fde3ec;
      --ink:#2b2b2b;
      --muted:#6f6f6f;
      --bg:#fff7fa;
      --shadow: 0 18px 45px rgba(0,0,0,.10);
      --shadow-soft: 0 12px 28px rgba(0,0,0,.08);
      --radius-xl: 22px;
      --radius-lg: 18px;
      --max: 1120px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:'Poppins',system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      background:var(--bg);
      color:var(--ink);
    }

    /* NAV */
    .nav{
      position:sticky;
      top:0;
      z-index:50;
      background:linear-gradient(90deg, rgba(240,143,176,.92), rgba(226,106,147,.92));
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 24px rgba(0,0,0,.10);
    }
    .nav-inner{
      max-width:var(--max);
      margin:0 auto;
      padding:14px 18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      color:#fff;
      text-decoration:none;
      font-weight:700;
      letter-spacing:.3px;
      white-space:nowrap;
    }
    .brand-badge{
      width:36px;height:36px;border-radius:12px;
      background:rgba(255,255,255,.22);
      display:grid;place-items:center;
      border:1px solid rgba(255,255,255,.25);
    }
    .brand small{display:block;font-weight:500;opacity:.92;margin-top:-2px}

    .menu{
      display:flex;
      gap:16px;
      align-items:center;
      flex-wrap:wrap;
      justify-content:flex-end;
    }
    .menu a{
      color:#fff;
      text-decoration:none;
      font-weight:600;
      font-size:.95rem;
      opacity:.95;
    }
    .menu a:hover{opacity:1;text-decoration:underline}

    .btn-pill{
      border:0;
      background:#fff;
      color:var(--pink-700);
      font-weight:700;
      padding:10px 14px;
      border-radius:999px;
      text-decoration:none;
      box-shadow: 0 10px 22px rgba(0,0,0,.12);
      white-space:nowrap;
    }

    /* HERO */
    .hero-wrap{
      max-width:var(--max);
      margin:0 auto;
      padding:26px 18px 0;
    }
    .hero{
      position:relative;
      border-radius:28px;
      overflow:hidden;
      min-height:360px;
      box-shadow: var(--shadow);
      background:
        linear-gradient(90deg, rgba(255,247,250,.92) 0%, rgba(255,247,250,.72) 44%, rgba(255,247,250,.10) 72%),
        url('https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&amp;fit=crop&amp;w=1600&amp;q=80');
      background-size:cover;
      background-position:center;
    }
    .hero-content{
      padding:56px 52px;
      max-width:620px;
    }
    .hero h1{
      margin:0 0 12px;
      font-size:3rem;
      letter-spacing:.2px;
      color:#3a3a3a;
    }
    .hero h1 span{color:var(--pink-700)}
    .hero p{
      margin:0 0 22px;
      color:#4b4b4b;
      font-size:1.06rem;
      line-height:1.7;
    }
    .cta{
      display:inline-block;
      background:linear-gradient(90deg, var(--pink-500), var(--pink-600));
      color:#fff;
      font-weight:700;
      padding:12px 18px;
      border-radius:12px;
      text-decoration:none;
      box-shadow: 0 14px 26px rgba(226,106,147,.35);
    }
    .cta:hover{filter:saturate(1.05);transform:translateY(-1px)}

    /* Wave separation */
    .wave{
      margin-top:-10px;
      height:70px;
      background: radial-gradient(120% 90% at 50% 0%, #ffffff 55%, rgba(255,255,255,0) 56%);
    }

    /* SECTIONS */
    section{scroll-margin-top:92px}
    .section{
      max-width:var(--max);
      margin:0 auto;
      padding:34px 18px;
    }

    /* Feature cards */
    .feature-grid{
      display:grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap:22px;
    }
    .feature{
      background:rgba(255,255,255,.88);
      border:1px solid rgba(240,143,176,.25);
      border-radius:var(--radius-xl);
      box-shadow: var(--shadow-soft);
      padding:26px 22px;
      text-align:center;
    }
    .icon{
      width:64px;height:64px;
      margin:0 auto 12px;
      border-radius:18px;
      background: linear-gradient(180deg, rgba(240,143,176,.35), rgba(226,106,147,.15));
      display:grid;place-items:center;
    }
    .feature h3{margin:8px 0 8px;color:#3b3b3b;font-size:1.25rem}
    .feature p{margin:0;color:var(--muted);font-size:.98rem}
    .feature .mini-btn{
      display:inline-block;
      margin-top:14px;
      padding:10px 14px;
      border-radius:12px;
      text-decoration:none;
      font-weight:700;
      color:#fff;
      background:linear-gradient(90deg, var(--pink-500), var(--pink-600));
    }

    /* Title block */
    .title{
      text-align:center;
      margin:26px 0 16px;
    }
    .title h2{margin:0;font-size:2.25rem;color:#3a3a3a}
    .title p{margin:8px 0 0;color:var(--muted)}
    .divider{
      width:120px;height:2px;margin:14px auto 0;
      background: linear-gradient(90deg, rgba(226,106,147,0), rgba(226,106,147,.85), rgba(226,106,147,0));
      border-radius:999px;
    }

    /* Professionals */
    .pros{
      display:grid;
      grid-template-columns: repeat(5, minmax(0,1fr));
      gap:18px;
      margin-top:22px;
    }
    .pro{
      text-align:center;
      padding:10px 6px;
    }
    .avatar{
      width:110px;height:110px;
      margin:0 auto 10px;
      border-radius:999px;
      background:#fff;
      overflow:hidden;
      border:4px solid rgba(240,143,176,.35);
      box-shadow: 0 10px 22px rgba(0,0,0,.10);
    }
    .avatar img{width:100%;height:100%;object-fit:cover}
    .pro strong{display:block;font-size:.96rem;color:#3a3a3a}
    .handle{display:block;font-size:.82rem;color:var(--muted);margin-top:2px}
    .pro a{display:inline-block;margin-top:6px;color:var(--pink-700);font-weight:700;text-decoration:none}
    .pro a:hover{text-decoration:underline}

    /* Resources lists */
    .list{
      display:grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap:14px;
      margin-top:18px;
    }
    .item{
      background:#fff;
      border-radius:var(--radius-lg);
      padding:14px 16px;
      box-shadow: var(--shadow-soft);
      border:1px solid rgba(240,143,176,.20);
      display:flex;
      gap:12px;
      align-items:center;
    }
    .bullet{
      width:12px;height:12px;border-radius:999px;
      background:linear-gradient(180deg, var(--pink-500), var(--pink-600));
      flex:0 0 12px;
    }
    .item a{
      color:#3a3a3a;
      text-decoration:none;
      font-weight:600;
    }
    .item a:hover{color:var(--pink-700);text-decoration:underline}

    /* Cartilha cover */
    .cover-wrap{display:flex;justify-content:center;margin-top:18px}
    .cover{
      width:min(420px, 100%);
      border-radius:18px;
      box-shadow: var(--shadow-soft);
      border:1px solid rgba(240,143,176,.25);
      overflow:hidden;
    }
    .cover img{width:100%;display:block}

    /* Contact */
    .contact-box{
      background:rgba(255,255,255,.90);
      border-radius:28px;
      padding:26px 18px;
      box-shadow: var(--shadow);
      text-align:center;
      border:1px solid rgba(240,143,176,.25);
    }
    .contact-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:16px}
    .contact-actions a{
      display:inline-block;
      min-width:180px;
      padding:12px 18px;
      border-radius:14px;
      font-weight:800;
      text-decoration:none;
      background:linear-gradient(90deg, var(--pink-500), var(--pink-600));
      color:#fff;
      box-shadow: 0 14px 26px rgba(226,106,147,.30);
    }

    /* Footer */
    footer{
      padding:26px 18px 38px;
      text-align:center;
      color:#6a6a6a;
    }
    footer .sig{font-size:.82rem;margin-top:8px;color:#7b7b7b}

    /* Responsive */
    @media (max-width: 980px){
      .feature-grid{grid-template-columns:1fr;}
      .pros{grid-template-columns: repeat(3, minmax(0,1fr));}
      .hero-content{padding:46px 26px}
      .hero h1{font-size:2.35rem}
      .list{grid-template-columns:1fr}
    }
    @media (max-width: 520px){
      .menu{gap:10px}
      .menu a{font-size:.88rem}
      .btn-pill{padding:9px 12px}
      .pros{grid-template-columns: repeat(2, minmax(0,1fr));}
      .avatar{width:96px;height:96px}
    }
  &lt;/style&gt;
&lt;/head&gt;
